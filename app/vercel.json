{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "cd server && npm install --production && cd .. && npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
